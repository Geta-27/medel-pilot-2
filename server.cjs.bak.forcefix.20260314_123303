app.post("/api/dispatch/decision", (req, res) => {
  try {
    const { insurance = "", language = "", specialty = "", locationText = "", limit = 5 } = req.body || {};

    // request-like object compatible with your matching logic
    const r = {
      insurance,
      language,
      specialty,
      locationText,
      triedProviderIds: [],
    };

    const elig = eligibleProviders(r);

    const candidates = elig
      .slice(0, Math.max(1, Math.min(50, Number(limit) || 5)))
      .map((p) => ({
        id: p.id,
        name: p.name,
        score: 100 - (p.load || 0) * 20, // simple MVP score: prefer low load
        load: p.load || 0,
        lastSeen: p.lastSeen || null,
        insurance: p.insurance,
        language: p.language,
        specialty: p.specialty,
        locationText: p.locationText,
        online: !!p.online,
      }));

    res.json({
      ok: true,
      recommendedProviderId: candidates[0]?.id ?? null,
      candidates,
    });
  } catch (e) {
    console.error("api/dispatch/decision error:", e);
    res.status(500).json({ ok: false, error: "server_error" });
  }
});

// ===== HEARTBEAT FIX (array-based providers) =====
app.post("/api/providers/heartbeat", (req, res) => {
  const id = (req.body && (req.body.id || req.body.providerId)) || "";
  if (!id || typeof id !== "string") {
    return res.status(400).json({ ok: false, error: "Missing provider id (id or providerId)" });
  }

  // DO NOT normalize provider IDs
  const p = providers.find(x => x.id === id);
  if (!p) {
    return res.status(404).json({ ok: false, error: "Provider not found", id });
  }

  p.lastSeen = Date.now();
  p.onlineEffective = !!p.online;

  return res.json({ ok: true, provider: p });
});

app.get("/api/requests", (_req, res) => res.json({ requests: requests.slice().sort((a,b)=>b.createdAt-a.createdAt) }));

app.post("/api/requests", (req, res) => {
  const body = req.body || {};
  const crypto = require("crypto");

  const requestId = String(
    body.requestId ||
    `req_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`
  );

  const request = {
    id: crypto.randomUUID(),
    requestId,
    createdAt: Date.now(),
    patientName: body.patientName || "Patient",
    reason: body.reason || "",
    locationText: body.locationText || "",
    insurance: String(body.insurance || "").toLowerCase(),
    language: String(body.language || "").toLowerCase(),
    specialty: String(body.specialty || "").replace(/_/g, " ").toLowerCase(),
    status: "PENDING",
    assignedProviderId: null,
    providerName: null,
    assignedAt: null,
    assignExpiresAt: null,
    reroutes: 0,
    triedProviderIds: [],
    slotStart: body.slotStart || null,
    slotEnd: body.slotEnd || null,
    bookingId: null,
  };

  requests.push(request);

  return res.json({
    ok: true,
    request,
  });
});

app.post("/api/requests/:id/accept", (req, res) => {
  const id = String(req.params.id);
  const { providerId, slotStart, slotEnd } = req.body || {};

  if (!Array.isArray(requests)) {
    return res.status(500).json({
      ok: false,
      error: "requests store not available",
    });
  }

  const r = requests.find((x) =>
    String(x.id) === id || String(x.requestId) === id
  );

  if (!r) {
    return res.status(404).json({
      ok: false,
      error: "request not found",
      id,
    });
  }

  const mustUseSlotLock = providerId && slotStart && slotEnd;

  if (mustUseSlotLock) {
    const check = confirmSlotLock({
      requestId: r.requestId || id,
      providerId,
      slotStart,
      slotEnd,
    });

    if (!check.ok) {
      return res.status(409).json({
        ok: false,
        error: check.reason,
        requestId: r.requestId || id,
        providerId,
        slotStart,
        slotEnd,
      });
    }

    slotLocks.delete(slotKey(providerId, slotStart, slotEnd));

    r.assignedProviderId = providerId;
    r.slotStart = slotStart;
    r.slotEnd = slotEnd;
    r.bookingId = r.bookingId || `bk_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
  }

  r.status = "ACCEPTED";
  r.assignedAt = Date.now();

  return res.json({
    ok: true,
    request: r,
  });
});

app.post("/api/requests/:id/complete", (req, res) => {
  const b = req.body || {};
  const providerId = norm(b.providerId);

  const r = requests.find(x => x.id === req.params.id);
  if (!r) return res.status(404).json({ error: "Not found" });

  // optional enforcement
  if (providerId && r.assignedProviderId && providerId !== r.assignedProviderId) {
    return res.status(403).json({ error: "Not your request" });
  }

  r.status = "COMPLETED";
  res.json({ request: r });
});

app.post("/api/providers/upsert", (req, res) => {
  const body = req.body || {};
  const id = body.id || crypto.randomUUID();

  const existing = providers.find(p => p.id === id) || {};

  const pObj = {
    id,
    name: body.name ?? existing.name ?? "provider",
    online:
      typeof body.online === "boolean"
        ? body.online
        : (typeof existing.online === "boolean" ? existing.online : true),
    maxLoad: Number(body.maxLoad ?? existing.maxLoad ?? 1),
    insurance: norm(body.insurance ?? existing.insurance ?? ""),
    language: norm(body.language ?? existing.language ?? ""),
    specialty: norm(body.specialty ?? existing.specialty ?? ""),
    locationText: norm(body.locationText ?? existing.locationText ?? ""),
    busyUntil:
      body.busyUntil === undefined
        ? (existing.busyUntil ?? null)
        : (body.busyUntil === null ? null : Number(body.busyUntil)),
    lastSeen: now(),
  };

  const idx = providers.findIndex(p => p.id === id);
  if (idx >= 0) providers[idx] = pObj;
  else providers.push(pObj);

  res.json({ ok: true, provider: pObj });
});


