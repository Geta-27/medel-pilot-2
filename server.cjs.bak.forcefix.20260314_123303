// =========================
// SLOT LOCKING (MVP PATCH)
// =========================
const SLOT_HOLD_MS = 90 * 1000;
const slotLocks = new Map();

function nowMs() {
  return Date.now();
}

function slotKey(providerId, slotStart, slotEnd) {
  return `${String(providerId)}__${String(slotStart)}__${String(slotEnd)}`;
}

function isExpiredLock(lock) {
  return !lock || lock.expiresAt <= nowMs();
}

function cleanupExpiredSlotLocks() {
  const now = nowMs();
  for (const [key, lock] of slotLocks.entries()) {
    if (!lock || lock.expiresAt <= now) {
      slotLocks.delete(key);
    }
  }
}

setInterval(cleanupExpiredSlotLocks, 15 * 1000);

function getActiveSlotLock(providerId, slotStart, slotEnd) {
  cleanupExpiredSlotLocks();
  const key = slotKey(providerId, slotStart, slotEnd);
  const lock = slotLocks.get(key);
  if (!lock) return null;
  if (isExpiredLock(lock)) {
    slotLocks.delete(key);
    return null;
  }
  return lock;
}

function acquireSlotLock({ requestId, providerId, slotStart, slotEnd }) {
  cleanupExpiredSlotLocks();
  const key = slotKey(providerId, slotStart, slotEnd);
  const existing = slotLocks.get(key);

  if (!existing || isExpiredLock(existing)) {
    const lock = {
      requestId,
      providerId,
      slotStart,
      slotEnd,
      createdAt: new Date().toISOString(),
      expiresAt: nowMs() + SLOT_HOLD_MS,
    };
    slotLocks.set(key, lock);
    return { ok: true, created: true, lock };
  }

  if (existing.requestId === requestId) {
    existing.expiresAt = nowMs() + SLOT_HOLD_MS;
    return { ok: true, created: false, lock: existing };
  }

  return {
    ok: false,
    reason: "SLOT_ALREADY_HELD",
    lock: existing,
  };
}

function confirmSlotLock({ requestId, providerId, slotStart, slotEnd }) {
  cleanupExpiredSlotLocks();
  const key = slotKey(providerId, slotStart, slotEnd);
  const existing = slotLocks.get(key);

  if (!existing || isExpiredLock(existing)) {
    if (existing && isExpiredLock(existing)) slotLocks.delete(key);
    return { ok: false, reason: "LOCK_NOT_FOUND_OR_EXPIRED" };
  }

  if (existing.requestId !== requestId) {
    return { ok: false, reason: "LOCK_OWNED_BY_OTHER_REQUEST", lock: existing };
  }

  return { ok: true, lock: existing };
}

function releaseSlotLock({ requestId, providerId, slotStart, slotEnd, force = false }) {
  cleanupExpiredSlotLocks();
  const key = slotKey(providerId, slotStart, slotEnd);
  const existing = slotLocks.get(key);

  if (!existing) return { ok: true, released: false };

  if (force || existing.requestId === requestId) {
    slotLocks.delete(key);
    return { ok: true, released: true };
  }

  return { ok: false, reason: "LOCK_OWNED_BY_OTHER_REQUEST", lock: existing };
}

app.get("/api/slots/locks", (_req, res) => {
  cleanupExpiredSlotLocks();
  res.json({
    ok: true,
    count: slotLocks.size,
    locks: Array.from(slotLocks.values()),
  });
});

app.post("/api/slots/hold", (req, res) => {
  const { requestId, providerId, slotStart, slotEnd } = req.body || {};

  if (!requestId || !providerId || !slotStart || !slotEnd) {
    return res.status(400).json({
      ok: false,
      error: "requestId, providerId, slotStart, slotEnd are required",
    });
  }

  const result = acquireSlotLock({ requestId, providerId, slotStart, slotEnd });

  if (!result.ok) {
    return res.status(409).json({
      ok: false,
      error: result.reason,
      heldByRequestId: result.lock?.requestId ?? null,
      providerId,
      slotStart,
      slotEnd,
      expiresAt: result.lock?.expiresAt ?? null,
    });
  }

  return res.json({
    ok: true,
    held: true,
    providerId,
    slotStart,
    slotEnd,
    requestId,
    expiresAt: result.lock.expiresAt,
  });
});

app.post("/api/slots/confirm", (req, res) => {
  const { requestId, providerId, slotStart, slotEnd } = req.body || {};

  if (!requestId || !providerId || !slotStart || !slotEnd) {
    return res.status(400).json({
      ok: false,
      error: "requestId, providerId, slotStart, slotEnd are required",
    });
  }

  const check = confirmSlotLock({ requestId, providerId, slotStart, slotEnd });

  if (!check.ok) {
    return res.status(409).json({
      ok: false,
      error: check.reason,
      providerId,
      slotStart,
      slotEnd,
    });
  }

  if (Array.isArray(requests)) {
    const r = requests.find((x) => x.requestId === requestId);
    if (r) {
      r.status = "ASSIGNED";
      r.assignedProviderId = providerId;
      r.slotStart = slotStart;
      r.slotEnd = slotEnd;
      r.bookingId = r.bookingId || `bk_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
    }
  }

  slotLocks.delete(slotKey(providerId, slotStart, slotEnd));

  return res.json({
    ok: true,
    confirmed: true,
    requestId,
    providerId,
    slotStart,
    slotEnd,
  });
});

app.post("/api/slots/release", (req, res) => {
  const { requestId, providerId, slotStart, slotEnd } = req.body || {};

  if (!requestId || !providerId || !slotStart || !slotEnd) {
    return res.status(400).json({
      ok: false,
      error: "requestId, providerId, slotStart, slotEnd are required",
    });
  }

  const result = releaseSlotLock({ requestId, providerId, slotStart, slotEnd });

  if (!result.ok) {
    return res.status(409).json({
      ok: false,
      error: result.reason,
    });
  }

  return res.json({
    ok: true,
    released: result.released,
  });
});

